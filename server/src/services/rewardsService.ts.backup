  /**
   * Confirm on-chain claim
   */
  static async confirmClaim(
    eventId: string,
    userId: string,
    claimType: ClaimType,
    transactionHash: string
  ): Promise<ClaimInfo | null> {
    const pool = await prisma.eventRewardsPool.findUnique({
      where: { eventId },
    });

    if (!pool) {
      return null;
    }

    const claim = await prisma.rewardClaim.update({
      where: {
        poolId_userId_claimType: {
          poolId: pool.id,
          userId,
          claimType,
        },
      },
      data: {
        status: ClaimStatus.CLAIMED,
        transactionHash,
        claimedAt: new Date(),
      },
    });

    // We don't need to update totalDisbursed here because it was updated when we credited the rewards


    // Record activity log
    await prisma.tokenActivityLog.create({
      data: {
        userId,
        actionType: 'REWARD',
        amount: claim.finalAmount,
        metadata: {
          eventId,
          claimId: claim.id,
          claimType,
          transactionHash,
        },
      },
    });

    return {
      id: claim.id,
      poolId: claim.poolId,
      userId: claim.userId,
      claimType: claim.claimType,
      baseAmount: claim.baseAmount,
      multiplier: claim.multiplier,
      finalAmount: claim.finalAmount,
      status: claim.status,
      // For CREDITED status, signature fields are null
      signature: null,
      signatureExpiry: null,
      transactionHash: claim.transactionHash,
      claimedAt: claim.claimedAt,
    };
  }




  // ==================== FINALIZATION ====================

  /**
   * Mark pool as finalized in database
   */
  static async finalizePool(
    eventId: string,
    actualParticipants: number,
    refundAmount: number,
    transactionHash?: string
  ): Promise<PoolInfo> {
    const pool = await prisma.eventRewardsPool.update({
      where: { eventId },
      data: {
        status: RewardsPoolStatus.FINALIZED,
        participantCount: actualParticipants,
        refundAmount,
        refundTxHash: transactionHash,
        finalizedAt: new Date(),
      },
    });

    return this.formatPoolInfo(pool);
  }

  /**
   * Execute full finalization (On-chain + DB)
   */
  static async executeFinalization(eventId: string): Promise<PoolInfo> {
    // 1. Get event analytics for participant count
    const analytics = await prisma.eventAnalytics.findUnique({
      where: { eventId }
    });

    const participantCount = analytics?.uniqueParticipants || 0;

    // 2. Execute on-chain finalization
    let txHash = undefined;
    try {
      txHash = await this.finalizeEventOnChain(eventId, participantCount);
      if (txHash === "ALREADY_FINALIZED") {
        txHash = undefined;
      }
    } catch (e) {
      throw e; // Fail if on-chain fails to keep consistency
    }

    // 3. Update DB
    const pool = await prisma.eventRewardsPool.findUnique({ where: { eventId } });
    if (!pool) throw new Error("Pool not found");

    let refundAmount = 0;
    if (pool.maxParticipants > participantCount) {
      const unused = pool.maxParticipants - participantCount;

      const { BASE_REWARD_VOTE_ONLY, BASE_REWARD_POST_VOTE, PLATFORM_FEE_PER_PARTICIPANT, USDC_DECIMALS } = REWARDS_CONSTANTS;
      const baseRefund = (BASE_REWARD_VOTE_ONLY / Math.pow(10, USDC_DECIMALS)) * unused;
      const platformFeeRefund = (PLATFORM_FEE_PER_PARTICIPANT / Math.pow(10, USDC_DECIMALS)) * unused;

      const event = await prisma.event.findUnique({ where: { id: eventId } });
      let creatorRefund = 0;
      if (event?.eventType === 'post_and_vote') {
        creatorRefund = (BASE_REWARD_POST_VOTE / Math.pow(10, USDC_DECIMALS)) * unused;
      }

      refundAmount = baseRefund + platformFeeRefund + creatorRefund;
    }

    return this.finalizePool(eventId, participantCount, refundAmount, txHash);
  }



  /**
   * Mark pool as cancelled in database
   */
  static async cancelPool(eventId: string, transactionHash?: string): Promise<PoolInfo> {
    const pool = await prisma.eventRewardsPool.findUnique({
      where: { eventId },
    });

    if (!pool) {
      throw new Error('Pool not found');
    }

    // Calculate refund (full amount since no claims)
    const totalRefund = pool.basePoolUsdc + pool.topPoolUsdc + pool.platformFeeUsdc + pool.creatorPoolUsdc;

    const updatedPool = await prisma.eventRewardsPool.update({
      where: { eventId },
      data: {
        status: RewardsPoolStatus.CANCELLED,
        refundAmount: totalRefund,
        refundTxHash: transactionHash,
        finalizedAt: new Date(),
      },
    });

    return this.formatPoolInfo(updatedPool);
  }

  // ==================== ON-CHAIN INTERACTIONS ====================

  /**
   * Finalize event on-chain (Execute transaction)
   * This requires the backend to have the OWNER private key or authorized role
   */
  static async finalizeEventOnChain(eventId: string, actualParticipants: number): Promise<string> {
    const contractAddress = process.env.REWARDS_VAULT_ADDRESS;
    // Use DEPLOYER_PRIVATE_KEY as owner, fallback to BACKEND_SIGNER_PRIVATE_KEY
    const privateKey = process.env.DEPLOYER_PRIVATE_KEY || process.env.BACKEND_SIGNER_PRIVATE_KEY;
    const rpcUrl = process.env.RPC_URL || 'https://rpc.sepolia.mantle.xyz'; // Default to Mantle Sepolia if not set

    if (!contractAddress || !privateKey) {
      throw new Error('Contract address or private key not configured');
    }

    try {
      const provider = new ethers.JsonRpcProvider(rpcUrl);
      const wallet = new ethers.Wallet(privateKey, provider);

      const abi = [
        'function finalizeEvent(bytes32 eventId, uint256 actualParticipants) external',
        'function eventPools(bytes32) view returns (uint8 state, uint8 eventType, address brandAddress, uint256 maxParticipants, uint256 basePool, uint256 topPool, uint256 platformFeePool, uint256 creatorPool, uint256 totalDisbursed, uint256 participantCount)'
      ];

      const contract = new ethers.Contract(contractAddress, abi, wallet);

      // Check current state
      const onChainEventId = this.generateOnChainEventId(eventId);
      const pool = await contract.eventPools(onChainEventId);

      // State 2 = Finalized. If already finalized, just return "Already Finalized" or hash
      if (pool.state === 2n || pool.state === 2) {
        console.log("Event already finalized on-chain");
        return "ALREADY_FINALIZED";
      }

      console.log(`Finalizing event ${eventId} (OnChain: ${onChainEventId}) with ${actualParticipants} participants...`);

      const tx = await contract.finalizeEvent(onChainEventId, actualParticipants);
      console.log(`Finalize tx sent: ${tx.hash}`);

      const receipt = await tx.wait();
      console.log(`Finalize tx confirmed in block ${receipt.blockNumber}`);

      return tx.hash;

    } catch (error: any) {
      console.error("Failed to finalize event on-chain:", error);
      throw new Error(`On-chain finalization failed: ${error.message}`);
    }
  }

  // ==================== BRAND REFUND MANAGEMENT ====================

  /**
   * Get brand's refundable balance across all events
   */
  static async getBrandRefundableBalance(brandId: string): Promise<{
    totalRefundable: number;
    totalLocked: number;
    totalDisbursed: number;
    pools: {
      eventId: string;
      eventTitle: string;
      status: RewardsPoolStatus;
      lockedAmount: number;
      disbursedAmount: number;
      refundableAmount: number;
      refundClaimed: boolean;
    }[];
  }> {
    // Get all events for this brand with their pools
    const events = await prisma.event.findMany({
      where: { brandId },
      include: {
        rewardsPool: true,
      },
    });

    const pools: {
      eventId: string;
      eventTitle: string;
      status: RewardsPoolStatus;
      lockedAmount: number;
      disbursedAmount: number;
      refundableAmount: number;
      refundClaimed: boolean;
    }[] = [];

    let totalRefundable = 0;
    let totalLocked = 0;
    let totalDisbursed = 0;

    for (const event of events) {
      const pool = event.rewardsPool;
      if (!pool) continue;

      const lockedAmount = pool.basePoolUsdc + pool.topPoolUsdc + pool.creatorPoolUsdc;
      const disbursedAmount = pool.totalDisbursed;

      // Calculate refundable based on pool status
      let refundableAmount = 0;
      const refundClaimed = !!pool.refundTxHash;

      if (pool.status === RewardsPoolStatus.FINALIZED && !refundClaimed) {
        // Finalized: refund is the pool's calculated refundAmount
        refundableAmount = pool.refundAmount || 0;
      } else if (pool.status === RewardsPoolStatus.CANCELLED && !refundClaimed) {
        // Cancelled: full refund (if no claims were made)
        refundableAmount = lockedAmount - disbursedAmount;
      } else if (pool.status === RewardsPoolStatus.ACTIVE) {
        // Active pools: cannot refund yet, but track locked amount
        // Refundable will be calculated when finalized
        refundableAmount = 0;
      }

      totalLocked += lockedAmount;
      totalDisbursed += disbursedAmount;
      totalRefundable += refundableAmount;

      pools.push({
        eventId: event.id,
        eventTitle: event.title,
        status: pool.status,
        lockedAmount,
        disbursedAmount,
        refundableAmount,
        refundClaimed,
      });
    }

    return {
      totalRefundable,
      totalLocked,
      totalDisbursed,
      pools,
    };
  }



  /**
   * Prepare refund claim data for brand
   * Returns the data needed to call the contract's finalizeEvent function
   */
  static async prepareRefundClaim(eventId: string, brandId: string): Promise<{
    success: boolean;
    data?: {
      onChainEventId: string;
      actualParticipants: number;
      refundAmount: number;
      encodedCallData: string;
    };
    error?: string;
  }> {
    // Get pool
    const pool = await prisma.eventRewardsPool.findUnique({
      where: { eventId },
      include: {
        event: {
          select: { brandId: true },
        },
      },
    });

    if (!pool) {
      return { success: false, error: 'Pool not found' };
    }

    // Verify brand ownership
    if (pool.event.brandId !== brandId) {
      return { success: false, error: 'Not authorized' };
    }

    // Check if already refunded
    if (pool.refundTxHash) {
      return { success: false, error: 'Refund already claimed' };
    }

    // Pool must be finalized
    if (pool.status !== RewardsPoolStatus.FINALIZED && pool.status !== RewardsPoolStatus.CANCELLED) {
      return { success: false, error: 'Pool must be finalized before claiming refund' };
    }

    // Calculate refund
    const lockedAmount = pool.basePoolUsdc + pool.topPoolUsdc + pool.creatorPoolUsdc + pool.platformFeeUsdc;
    const refundAmount = pool.refundAmount || (lockedAmount - pool.totalDisbursed);

    // Encode the finalizeEvent call data for the contract
    // Note: The actual finalization may have already happened on-chain
    // This is for the case where we need to trigger it
    const { USDC_DECIMALS } = REWARDS_CONSTANTS;
    const refundAmountRaw = BigInt(Math.floor(refundAmount * Math.pow(10, USDC_DECIMALS)));

    return {
      success: true,
      data: {
        onChainEventId: pool.onChainEventId,
        actualParticipants: pool.participantCount,
        refundAmount,
        encodedCallData: `0x`, // Contract-specific encoding would go here
      },
    };
  }

  /**
   * Mark refund as claimed
   */
  static async markRefundClaimed(eventId: string, transactionHash: string): Promise<PoolInfo | null> {
    const pool = await prisma.eventRewardsPool.findUnique({
      where: { eventId },
    });

    if (!pool) {
      return null;
    }

    const updatedPool = await prisma.eventRewardsPool.update({
      where: { eventId },
      data: {
        refundTxHash: transactionHash,
      },
    });

    return this.formatPoolInfo(updatedPool);
  }
}
