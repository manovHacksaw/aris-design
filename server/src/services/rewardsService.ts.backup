import { ethers } from 'ethers';
import { prisma } from '../lib/prisma.js';
import { ClaimType, ClaimStatus, RewardsPoolStatus, EventType as PrismaEventType } from '@prisma/client';
import { XpService } from './xpService.js';
import {
  REWARDS_CONSTANTS,
  EventType,
  PoolRequirements,
  PoolCalculationParams,
  PoolInfo,
  ClaimInfo,
  UserClaimableRewards,
  SignClaimResponse,
  ProcessEventRewardsResult,
  ClaimHistoryItem,
  UserClaimHistory,
} from '../types/rewards.js';




export class RewardsService {
  // ==================== CONTRACT INTERACTION ====================

  /**
   * Credit rewards to a user on-chain via RewardsVaultV2 contract
   */
  private static async creditRewardsOnChain(
    eventId: string,
    userAddress: string,
    amount: number
  ): Promise<void> {
    const contractAddress = process.env.REWARDS_VAULT_ADDRESS;
    const privateKey = process.env.DEPLOYER_PRIVATE_KEY || process.env.BACKEND_SIGNER_PRIVATE_KEY;
    const rpcUrl = process.env.RPC_URL || 'https://rpc.sepolia.mantle.xyz';
    const chainId = parseInt(process.env.CHAIN_ID || '5003');

    if (!contractAddress || !privateKey) {
      throw new Error('Contract address or private key not configured');
    }

    // Look up the on-chain event ID from the database (stored when pool was created)
    const pool = await prisma.eventRewardsPool.findUnique({
      where: { eventId },
      select: { onChainEventId: true }
    });

    if (!pool?.onChainEventId) {
      throw new Error(`No on-chain event ID found for event ${eventId}`);
    }

    const eventIdBytes32 = pool.onChainEventId;

    // Convert amount to USDC units (6 decimals)
    const amountInUsdc = BigInt(Math.round(amount * 1_000_000));

    if (amountInUsdc === 0n) {
      console.log(`[RewardsService] ⚠️  Skipping zero amount credit for Smart Account ${userAddress}`);
      return;
    }

    // Setup contract
    const provider = new ethers.JsonRpcProvider(rpcUrl);
    const wallet = new ethers.Wallet(privateKey, provider);
    const contract = new ethers.Contract(
      contractAddress,
      [
        'function creditRewards(bytes32 eventId, address user, uint256 amount)',
        'function getAccumulatedRewards(address user) view returns (uint256)'
      ],
      wallet
    );

    // ✅ FIX: Check if user already has accumulated balance
    const currentBalance = await contract.getAccumulatedRewards(userAddress);

    if (currentBalance >= amountInUsdc) {
      console.log(`[RewardsService] ✅ User ${userAddress} already has ${ethers.formatUnits(currentBalance, 6)} USDC accumulated (need ${amount}), skipping credit`);
      return; // Already credited, don't try again
    }

    // Only credit the difference if user has partial balance
    const amountToCredit = amountInUsdc - currentBalance;

    if (amountToCredit <= 0n) {
      console.log(`[RewardsService] ✅ User ${userAddress} already has sufficient balance, skipping`);
      return;
    }

    console.log(`[RewardsService] 💰 Crediting ${ethers.formatUnits(amountToCredit, 6)} USDC to Smart Account ${userAddress} for event ${eventId}`);
    if (currentBalance > 0n) {
      console.log(`[RewardsService] 📊 User already has ${ethers.formatUnits(currentBalance, 6)} USDC, crediting difference`);
    }

    const tx = await contract.creditRewards(
      eventIdBytes32,
      userAddress,
      amountToCredit
    );

    console.log(`[RewardsService] Transaction sent: ${tx.hash}`);
    await tx.wait();
    console.log(`[RewardsService] Transaction confirmed`);
  }

  // ==================== POOL CALCULATIONS ====================

  /**
   * Calculate all pool requirements for creating an event reward pool
   */
  static calculatePoolRequirements(params: PoolCalculationParams): PoolRequirements {
    const { eventType, maxParticipants, topPoolAmount } = params;
    const { BASE_REWARD_VOTE_ONLY, BASE_REWARD_POST_VOTE, PLATFORM_FEE_PER_PARTICIPANT, MIN_TOP_REWARD_MULTIPLIER, USDC_DECIMALS } = REWARDS_CONSTANTS;

    // Calculate base pool
    const basePoolRaw = BigInt(BASE_REWARD_VOTE_ONLY) * BigInt(maxParticipants);
    const basePoolUsdc = Number(basePoolRaw) / Math.pow(10, USDC_DECIMALS);

    // Convert top pool amount to raw (input is in USDC)
    const topPoolRaw = BigInt(Math.floor(topPoolAmount * Math.pow(10, USDC_DECIMALS)));
    const topPoolUsdc = topPoolAmount;

    // Validate top pool is at least 2x base pool
    const minTopPool = basePoolRaw * BigInt(MIN_TOP_REWARD_MULTIPLIER);
    if (topPoolRaw < minTopPool) {
      throw new Error(`Top pool must be at least ${Number(minTopPool) / Math.pow(10, USDC_DECIMALS)} USDC (2x base pool)`);
    }

    // Calculate platform fee
    const platformFeeRaw = BigInt(PLATFORM_FEE_PER_PARTICIPANT) * BigInt(maxParticipants);
    const platformFeeUsdc = Number(platformFeeRaw) / Math.pow(10, USDC_DECIMALS);

    // Calculate creator pool for post_and_vote events
    let creatorPoolRaw = 0n;
    let creatorPoolUsdc = 0;
    if (eventType === EventType.PostAndVote) {
      creatorPoolRaw = BigInt(BASE_REWARD_POST_VOTE) * BigInt(maxParticipants);
      creatorPoolUsdc = Number(creatorPoolRaw) / Math.pow(10, USDC_DECIMALS);
    }

    // Calculate total
    const totalRequiredRaw = basePoolRaw + topPoolRaw + platformFeeRaw + creatorPoolRaw;
    const totalRequiredUsdc = Number(totalRequiredRaw) / Math.pow(10, USDC_DECIMALS);

    return {
      basePoolUsdc,
      topPoolUsdc,
      platformFeeUsdc,
      creatorPoolUsdc,
      totalRequiredUsdc,
      basePoolRaw,
      topPoolRaw,
      platformFeeRaw,
      creatorPoolRaw,
      totalRequiredRaw,
    };
  }

  /**
   * Generate on-chain event ID (bytes32 hash)
   */
  static generateOnChainEventId(eventId: string): string {
    return ethers.keccak256(ethers.toUtf8Bytes(eventId));
  }

  // ==================== POOL MANAGEMENT ====================

  /**
   * Create a rewards pool record in the database
   * Note: Actual on-chain pool creation is done by the brand via frontend
   */
  static async createPoolRecord(
    eventId: string,
    maxParticipants: number,
    topPoolAmount: number,
    transactionHash?: string
  ): Promise<PoolInfo> {
    // Get event details
    const event = await prisma.event.findUnique({
      where: { id: eventId },
      include: { brand: true },
    });

    if (!event) {
      throw new Error('Event not found');
    }

    // Check if pool already exists
    const existingPool = await prisma.eventRewardsPool.findUnique({
      where: { eventId },
    });

    if (existingPool) {
      throw new Error('Rewards pool already exists for this event');
    }

    // Determine event type
    const eventType = event.eventType === 'post_and_vote' ? EventType.PostAndVote : EventType.VoteOnly;

    // Calculate pool requirements
    const requirements = this.calculatePoolRequirements({
      eventType,
      maxParticipants,
      topPoolAmount,
    });

    // Generate on-chain event ID
    const onChainEventId = this.generateOnChainEventId(eventId);

    // Create pool record
    const pool = await prisma.eventRewardsPool.create({
      data: {
        eventId,
        onChainEventId,
        transactionHash,
        maxParticipants,
        basePoolUsdc: requirements.basePoolUsdc,
        topPoolUsdc: requirements.topPoolUsdc,
        platformFeeUsdc: requirements.platformFeeUsdc,
        creatorPoolUsdc: requirements.creatorPoolUsdc,
        status: transactionHash ? RewardsPoolStatus.ACTIVE : RewardsPoolStatus.PENDING,
      },
    });

    return this.formatPoolInfo(pool);
  }

  /**
   * Update pool status after on-chain transaction
   */
  static async activatePool(eventId: string, transactionHash: string): Promise<PoolInfo> {
    const pool = await prisma.eventRewardsPool.update({
      where: { eventId },
      data: {
        status: RewardsPoolStatus.ACTIVE,
        transactionHash,
      },
    });

    return this.formatPoolInfo(pool);
  }

  /**
   * Get pool info for an event
   */
  static async getPoolInfo(eventId: string): Promise<PoolInfo | null> {
    const pool = await prisma.eventRewardsPool.findUnique({
      where: { eventId },
    });

    if (!pool) {
      return null;
    }

    return this.formatPoolInfo(pool);
  }

  /**
   * Format pool record to PoolInfo
   */
  private static formatPoolInfo(pool: any): PoolInfo {
    const totalPool = pool.basePoolUsdc + pool.topPoolUsdc + pool.creatorPoolUsdc;
    const remainingPoolUsdc = Math.max(0, totalPool - pool.totalDisbursed);

    return {
      id: pool.id,
      eventId: pool.eventId,
      onChainEventId: pool.onChainEventId,
      transactionHash: pool.transactionHash,
      maxParticipants: pool.maxParticipants,
      basePoolUsdc: pool.basePoolUsdc,
      topPoolUsdc: pool.topPoolUsdc,
      platformFeeUsdc: pool.platformFeeUsdc,
      creatorPoolUsdc: pool.creatorPoolUsdc,
      totalDisbursed: pool.totalDisbursed,
      participantCount: pool.participantCount,
      status: pool.status,
      remainingPoolUsdc,
      finalizedAt: pool.finalizedAt,
      refundAmount: pool.refundAmount,
    };
  }

  // ==================== EVENT REWARDS PROCESSING ====================

  /**
   * Process event rewards after completion
   * Creates claim records for all eligible participants
   */
  static async processEventRewards(eventId: string): Promise<ProcessEventRewardsResult> {
    const result: ProcessEventRewardsResult = {
      success: false,
      claimsCreated: 0,
      totalRewards: 0,
      errors: [],
    };

    try {
      // Get pool
      const pool = await prisma.eventRewardsPool.findUnique({
        where: { eventId },
      });

      if (!pool) {
        result.errors.push('No rewards pool found for this event');
        return result;
      }

      if (pool.status !== RewardsPoolStatus.ACTIVE) {
        result.errors.push(`Pool is not active (status: ${pool.status})`);
        return result;
      }

      // Get event with votes and submissions
      const event = await prisma.event.findUnique({
        where: { id: eventId },
        include: {
          votes: {
            include: {
              user: {
                select: { id: true, walletAddress: true, xp: true },
              },
            },
          },
          submissions: {
            where: { status: 'active' },
            include: {
              user: {
                select: { id: true, walletAddress: true, xp: true },
              },
              _count: {
                select: { votes: true },
              },
            },
            orderBy: { finalRank: 'asc' },
          },
        },
      });

      if (!event) {
        result.errors.push('Event not found');
        return result;
      }

      const claimsToCreate: any[] = [];
      const { USDC_DECIMALS, BASE_REWARD_VOTE_ONLY, BASE_REWARD_POST_VOTE, FIRST_PLACE_BPS, SECOND_PLACE_BPS, THIRD_PLACE_BPS, BPS_DENOMINATOR } = REWARDS_CONSTANTS;

      // Process voter base rewards
      const uniqueVoters = new Map<string, { userId: string; walletAddress: string | null; xp: number }>();
      for (const vote of event.votes) {
        if (vote.user.walletAddress && !uniqueVoters.has(vote.userId)) {
          uniqueVoters.set(vote.userId, {
            userId: vote.userId,
            walletAddress: vote.user.walletAddress,
            xp: vote.user.xp,
          });
        }
      }
      console.log(`Debug: Found ${uniqueVoters.size} unique eligible voters`);

      // Create base voter reward claims
      for (const [userId, voter] of uniqueVoters) {
        const { multiplier } = XpService.calculateLevel(voter.xp);
        const baseAmount = BASE_REWARD_VOTE_ONLY / Math.pow(10, USDC_DECIMALS);
        const finalAmount = baseAmount * multiplier;

        claimsToCreate.push({
          poolId: pool.id,
          userId,
          claimType: ClaimType.BASE_VOTER,
          baseAmount,
          multiplier,
          finalAmount,
          status: ClaimStatus.PENDING,
        });
      }

      // Calculate top voter rewards
      // For post_and_vote: top 3 voters by total votes on winning content
      // For vote_only: voters who voted for top 3 proposals
      if (event.eventType === 'post_and_vote') {
        // Get top 3 submissions
        const topSubmissions = event.submissions.slice(0, 3);

        // Get voters who voted on top content
        const topVoters = new Map<string, { count: number; xp: number }>();
        for (const submission of topSubmissions) {
          const votes = await prisma.vote.findMany({
            where: {
              eventId,
              submissionId: submission.id,
            },
            include: {
              user: { select: { id: true, xp: true, walletAddress: true } },
            },
          });

          for (const vote of votes) {
            if (vote.user.walletAddress) {
              const current = topVoters.get(vote.userId) || { count: 0, xp: vote.user.xp };
              topVoters.set(vote.userId, { count: current.count + 1, xp: vote.user.xp });
            }
          }
        }

        // Sort by count and give top voter rewards
        const sortedTopVoters = Array.from(topVoters.entries())
          .sort((a, b) => b[1].count - a[1].count)
          .slice(0, 3);

        const topVoterPercentages = [FIRST_PLACE_BPS, SECOND_PLACE_BPS, THIRD_PLACE_BPS];

        for (let i = 0; i < sortedTopVoters.length; i++) {
          const [userId, data] = sortedTopVoters[i];
          const { multiplier } = XpService.calculateLevel(data.xp);
          const percentage = topVoterPercentages[i];
          const baseAmount = (pool.topPoolUsdc * percentage) / BPS_DENOMINATOR;
          const finalAmount = baseAmount * multiplier;

          claimsToCreate.push({
            poolId: pool.id,
            userId,
            claimType: ClaimType.TOP_VOTER,
            baseAmount,
            multiplier,
            finalAmount,
            status: ClaimStatus.CREDITED, // Changed from PENDING to CREDITED
          });
        }

        // Creator rewards (for post_and_vote)
        for (const submission of event.submissions) {
          if (!submission.user.walletAddress) continue;

          const { multiplier } = XpService.calculateLevel(submission.user.xp);
          const votesReceived = submission._count.votes;
          const baseAmount = (BASE_REWARD_POST_VOTE / Math.pow(10, USDC_DECIMALS)) * votesReceived;
          const finalAmount = baseAmount * multiplier;

          claimsToCreate.push({
            poolId: pool.id,
            userId: submission.userId,
            claimType: ClaimType.CREATOR,
            baseAmount,
            multiplier,
            finalAmount,
            status: ClaimStatus.CREDITED, // Changed from PENDING to CREDITED
          });
        }

        // Leaderboard rewards for top 3 creators
        const topCreators = event.submissions.slice(0, 3);
        const leaderboardPercentages = [FIRST_PLACE_BPS, SECOND_PLACE_BPS, THIRD_PLACE_BPS];

        for (let i = 0; i < topCreators.length; i++) {
          const creator = topCreators[i];
          if (!creator.user.walletAddress) continue;

          const { multiplier } = XpService.calculateLevel(creator.user.xp);
          const percentage = leaderboardPercentages[i];
          // Leaderboard rewards come from remaining top pool
          const baseAmount = (pool.topPoolUsdc * percentage) / BPS_DENOMINATOR / 2; // Split with top voters
          const finalAmount = baseAmount * multiplier;

          claimsToCreate.push({
            poolId: pool.id,
            userId: creator.userId,
            claimType: ClaimType.LEADERBOARD,
            baseAmount,
            multiplier,
            finalAmount,
            status: ClaimStatus.CREDITED, // Changed from PENDING to CREDITED
          });
        }
      } else {
        // vote_only event - top voter rewards for voting on winning proposals
        const topProposals = await prisma.proposal.findMany({
          where: { eventId },
          orderBy: { finalRank: 'asc' },
          take: 3,
        });

        const topVoterPercentages = [FIRST_PLACE_BPS, SECOND_PLACE_BPS, THIRD_PLACE_BPS];

        // Find voters who voted on winning proposals
        for (let i = 0; i < topProposals.length; i++) {
          const proposal = topProposals[i];
          const votes = await prisma.vote.findMany({
            where: {
              eventId,
              proposalId: proposal.id,
            },
            include: {
              user: { select: { id: true, xp: true, walletAddress: true } },
            },
          });

          // All voters on this proposal share the position reward
          const percentage = topVoterPercentages[i];
          const totalForPosition = (pool.topPoolUsdc * percentage) / BPS_DENOMINATOR;
          const perVoter = votes.length > 0 ? totalForPosition / votes.length : 0;

          for (const vote of votes) {
            if (!vote.user.walletAddress) continue;

            const { multiplier } = XpService.calculateLevel(vote.user.xp);
            const baseAmount = perVoter;
            const finalAmount = baseAmount * multiplier;

            claimsToCreate.push({
              poolId: pool.id,
              userId: vote.userId,
              claimType: ClaimType.TOP_VOTER,
              baseAmount,
              multiplier,
              finalAmount,
              status: ClaimStatus.PENDING,
            });
          }
        }
      }

      // Calculate total rewards
      result.totalRewards = claimsToCreate.reduce((sum, claim) => sum + claim.finalAmount, 0);

      // Batch create claims with extended timeout for large events
      await prisma.$transaction(
        async (tx) => {
          for (const claim of claimsToCreate) {
            try {
              await tx.rewardClaim.upsert({
                where: {
                  poolId_userId_claimType: {
                    poolId: claim.poolId,
                    userId: claim.userId,
                    claimType: claim.claimType,
                  },
                },
                create: claim,
                update: {}, // Don't update if exists
              });
              result.claimsCreated++;
            } catch (error: any) {
              // Skip duplicates
              if (error.code !== 'P2002') {
                result.errors.push(`Failed to create claim for user ${claim.userId}: ${error.message}`);
              }
            }
          }

          // Credit rewards on-chain for each user
          console.log(`[RewardsService] Crediting rewards on-chain for ${claimsToCreate.length} claims`);

          // Group claims by user to batch credit
          const userRewards = new Map<string, { userId: string; walletAddress: string; totalAmount: number }>();

          for (const claim of claimsToCreate) {
            const user = await tx.user.findUnique({
              where: { id: claim.userId },
              select: { walletAddress: true }
            });

            if (!user?.walletAddress) {
              console.warn(`[RewardsService] User ${claim.userId} has no wallet address, skipping on-chain credit`);
              continue;
            }

            const existing = userRewards.get(claim.userId);
            if (existing) {
              existing.totalAmount += claim.finalAmount;
            } else {
              userRewards.set(claim.userId, {
                userId: claim.userId,
                walletAddress: user.walletAddress,
                totalAmount: claim.finalAmount
              });
            }
          }

          // Update participant count
          await tx.eventRewardsPool.update({
            where: { id: pool.id },
            data: { participantCount: uniqueVoters.size },
          });
        },
        {
          timeout: 30000, // 30 seconds timeout for processing many claims
          maxWait: 10000, // Max 10 seconds to acquire connection
        }
      );

      // Credit rewards on-chain (outside transaction to avoid long-running tx)
      console.log(`[RewardsService] 🚀 Starting on-chain crediting for event ${eventId}`);
      const userRewards = new Map<string, { walletAddress: string; totalAmount: number }>();

      for (const claim of claimsToCreate) {
        const user = await prisma.user.findUnique({
          where: { id: claim.userId },
          select: { walletAddress: true }
        });

        if (!user?.walletAddress) {
          console.warn(`[RewardsService] ⚠️  User ${claim.userId} has no Smart Account address, skipping reward credit`);
          continue;
        }

        const existing = userRewards.get(user.walletAddress);
        if (existing) {
          existing.totalAmount += claim.finalAmount;
        } else {
          userRewards.set(user.walletAddress, {
            walletAddress: user.walletAddress,
            totalAmount: claim.finalAmount
          });
        }
      }

      // Credit each user on-chain
      for (const [walletAddress, { totalAmount }] of userRewards.entries()) {
        try {
          await this.creditRewardsOnChain(eventId, walletAddress, totalAmount);

          // ✅ FIX: Mark claims as CREDITED after successful on-chain crediting
          await prisma.rewardClaim.updateMany({
            where: {
              pool: { eventId },
              user: { walletAddress },
              status: ClaimStatus.PENDING
            },
            data: { status: ClaimStatus.CREDITED }
          });

          console.log(`[RewardsService] ✅ Updated claims to CREDITED for ${walletAddress}`);
        } catch (error: any) {
          console.error(`[RewardsService] Failed to credit ${walletAddress} on-chain:`, error.message);
          result.errors.push(`Failed to credit ${walletAddress}: ${error.message}`);
        }
      }

      result.success = true;
    } catch (error: any) {
      result.errors.push(`Processing failed: ${error.message}`);
    }

    return result;
  }

  // ==================== CLAIMS ====================

  /**
   * Get user's claims for an event
   */
  static async getUserClaims(eventId: string, userId: string): Promise<ClaimInfo[]> {
    const pool = await prisma.eventRewardsPool.findUnique({
      where: { eventId },
    });

    if (!pool) {
      return [];
    }

    const claims = await prisma.rewardClaim.findMany({
      where: {
        poolId: pool.id,
        userId,
      },
    });

    return claims.map((claim) => ({
      id: claim.id,
      poolId: claim.poolId,
      userId: claim.userId,
      claimType: claim.claimType,
      baseAmount: claim.baseAmount,
      multiplier: claim.multiplier,
      finalAmount: claim.finalAmount,
      status: claim.status,
      signature: claim.signature,
      signatureExpiry: claim.signatureExpiry,
      transactionHash: claim.transactionHash,
      claimedAt: claim.claimedAt,
    }));
  }

  /**
   * Get all claimable rewards for a user
   */
  static async getUserClaimableRewards(userId: string): Promise<UserClaimableRewards[]> {
    const claims = await prisma.rewardClaim.findMany({
      where: {
        userId,
        status: {
          in: [ClaimStatus.PENDING, ClaimStatus.SIGNED, ClaimStatus.CREDITED],
        },
      },
      include: {
        pool: {
          include: {
            event: {
              select: { id: true, title: true },
            },
          },
        },
      },
    });

    // Group by event
    const byEvent = new Map<string, UserClaimableRewards>();

    for (const claim of claims) {
      const eventId = claim.pool.eventId;
      const eventTitle = claim.pool.event.title;
      const onChainEventId = claim.pool.onChainEventId;

      if (!byEvent.has(eventId)) {
        byEvent.set(eventId, {
          eventId,
          eventTitle,
          onChainEventId,
          claims: [],
          totalClaimableUsdc: 0,
        });
      }

      const eventRewards = byEvent.get(eventId)!;
      eventRewards.claims.push({
        id: claim.id,
        poolId: claim.poolId,
        userId: claim.userId,
        claimType: claim.claimType,
        baseAmount: claim.baseAmount,
        multiplier: claim.multiplier,
        finalAmount: claim.finalAmount,
        status: claim.status,
        signature: claim.signature,
        signatureExpiry: claim.signatureExpiry,
        transactionHash: claim.transactionHash,
        claimedAt: claim.claimedAt,
        createdAt: claim.createdAt,
      });
      eventRewards.totalClaimableUsdc += claim.finalAmount;
    }

    return Array.from(byEvent.values());
  }

  /**
   * Get user's claim history
   */
  static async getUserClaimHistory(userId: string): Promise<UserClaimHistory> {
    const claims = await prisma.rewardClaim.findMany({
      where: { userId },
      include: {
        pool: {
          include: {
            event: {
              select: { id: true, title: true },
            },
          },
        },
      },
      orderBy: { createdAt: 'desc' },
    });

    let totalClaimedUsdc = 0;
    let totalPendingUsdc = 0;

    const claimHistory: ClaimHistoryItem[] = claims.map((claim) => {
      if (claim.status === ClaimStatus.CLAIMED) {
        totalClaimedUsdc += claim.finalAmount;
      } else if (claim.status === ClaimStatus.PENDING || claim.status === ClaimStatus.SIGNED || claim.status === ClaimStatus.CREDITED) {
        totalPendingUsdc += claim.finalAmount;
      }

      return {
        id: claim.id,
        eventId: claim.pool.eventId,
        eventTitle: claim.pool.event.title,
        claimType: claim.claimType,
        baseAmount: claim.baseAmount,
        multiplier: claim.multiplier,
        finalAmount: claim.finalAmount,
        status: claim.status,
        claimedAt: claim.claimedAt,
        transactionHash: claim.transactionHash,
      };
    });

    return {
      claims: claimHistory,
      totalClaimedUsdc,
      totalPendingUsdc,
    };
  }

  // ==================== EIP-712 SIGNATURE ====================

  /**
   * Generate EIP-712 signature for a claim
   */
  static async signClaim(
    eventId: string,
    userId: string,
    claimType: ClaimType,
    userAddress: string,
    nonceOffset: number = 0
  ): Promise<SignClaimResponse> {
