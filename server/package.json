{
  "name": "aris-server",
  "version": "1.0.0",
  "description": "ARIS Server with Express, Prisma, and Supabase",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "build": "prisma generate && bun build src/server.ts --outdir dist --target node",
    "start": "bun run dist/server.js",
    "prisma:generate": "bun prisma generate",
    "prisma:migrate": "bun prisma migrate dev",
    "prisma:studio": "bun prisma studio",
    "prisma:push": "bun prisma db push",
    "clean:events": "bun run src/scripts/cleanEvents.ts",
    "clean:all": "bun run src/scripts/cleanAllContent.ts",
    "test:auth": "bun test-auth.ts",
    "test:unauth": "bun test-unauthenticated.ts",
    "test:cycle": "bun run src/scripts/testEventCycle.ts",
    "inspect:event": "bun run src/scripts/inspectEvent.ts",
    "test": "NODE_ENV=test bun test tests/**/*.test.ts --timeout 30000",
    "test:watch": "NODE_ENV=test bun test tests/**/*.test.ts --watch --timeout 30000",
    "test:auth-suite": "NODE_ENV=test bun test tests/auth/ --timeout 30000",
    "test:users": "NODE_ENV=test bun test tests/users/ --timeout 30000",
    "test:events": "NODE_ENV=test bun test tests/events/ --timeout 30000",
    "test:rewards": "NODE_ENV=test bun test tests/rewards/ --timeout 30000",
    "test:admin": "NODE_ENV=test bun test tests/admin/ --timeout 30000",
    "test:integration": "NODE_ENV=test bun test tests/integration/ --timeout 60000",
    "test:db:push": "DATABASE_URL=$TEST_DATABASE_URL bun prisma db push"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@arcjet/node": "^1.4.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.10.2",
    "@privy-io/server-auth": "^1.32.5",
    "axios": "^1.13.2",
    "call-bind-apply-helpers": "^1.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "express": "^4.21.1",
    "firebase-admin": "^13.6.0",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^7.0.11",
    "permissionless": "^0.3.4",
    "pino": "^10.3.1",
    "react-datetime-picker": "^7.0.1",
    "socket.io": "^4.8.3",
    "viem": "^2.44.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/form-data": "^2.5.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.5",
    "@types/nodemailer": "^7.0.4",
    "@types/socket.io": "^3.0.2",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.10.2",
    "typescript": "^5.6.3"
  }
}
